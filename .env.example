# Core
DEBUG=True
SECRET_KEY=unsafe-dev-secret-key-change-me
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
CORS_ALLOWED_ORIGINS=

# Database (use ONE option)
# Option A: full URL
DATABASE_URL=postgres://estoque_app:<SENHA_FORTE_AQUI>@localhost:5433/sistema_estoque_prod

# Option B: split settings (preferred when DATABASE_URL not used)
POSTGRES_DB=sistema_estoque_prod
POSTGRES_USER=estoque_app
POSTGRES_PASSWORD=<SENHA_FORTE_AQUI>
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

# Security/Session
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SESSION_COOKIE_AGE=28800

# JWT
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=1

# Login rate limit
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# DRF throttling
DRF_THROTTLE_ANON=60/min
DRF_THROTTLE_USER=300/min
DRF_THROTTLE_CATEGORIAS=120/hour
DRF_THROTTLE_PRODUTOS=300/hour
DRF_THROTTLE_FORNECEDORES=120/hour
DRF_THROTTLE_CLIENTES=150/hour
DRF_THROTTLE_COMPRAS=200/hour
DRF_THROTTLE_VENDAS=200/hour
DRF_THROTTLE_FINANCEIRO=300/hour
